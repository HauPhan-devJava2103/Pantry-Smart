<?xml version="1.0" encoding="utf-8"?>
<!-- Item cho mỗi lần nấu ăn trong RecyclerView lịch sử -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_history_card"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical">

    <!-- Ảnh món ăn (bo tròn) -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivDishImage"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_restaurant"
        android:layout_marginEnd="12dp"
        android:background="#E5E7EB" />

    <!-- Thông tin -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Tên món -->
        <TextView
            android:id="@+id/tvHistoryRecipeName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tên món ăn"
            android:textColor="#1E1E2E"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Nguyên liệu đã dùng -->
        <TextView
            android:id="@+id/tvHistoryIngredients"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Nguyên liệu..."
            android:textColor="#6B7280"
            android:textSize="11sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Thời gian -->
        <TextView
            android:id="@+id/tvHistoryTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="2 giờ trước"
            android:textColor="#9CA3AF"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Nút xem lại công thức -->
    <TextView
        android:id="@+id/btnViewRecipe"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:gravity="center"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:text="Xem lại"
        android:textColor="#10B981"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/bg_view_recipe_btn" />
</LinearLayout>
