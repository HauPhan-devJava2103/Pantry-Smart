<?xml version="1.0" encoding="utf-8"?>
<!-- Item cho mỗi lần nấu ăn trong RecyclerView lịch sử -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_history_card"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <!-- Row 1: Ảnh + Tên + Thời gian + Nút -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Ảnh món ăn (bo tròn) -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivDishImage"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_restaurant"
            android:layout_marginEnd="12dp"
            android:background="#E5E7EB"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium" />

        <!-- Tên + Thời gian -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Tên món -->
            <TextView
                android:id="@+id/tvHistoryRecipeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên món ăn"
                android:textColor="#1E1E2E"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Thời gian -->
            <TextView
                android:id="@+id/tvHistoryTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="2 giờ trước"
                android:textColor="#9CA3AF"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Nút xem lại công thức -->
        <TextView
            android:id="@+id/btnViewRecipe"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="Xem lại"
            android:textColor="#10B981"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_view_recipe_btn" />
    </LinearLayout>

    <!-- Row 2: Nguyên liệu đã dùng (hiển thị đầy đủ) -->
    <TextView
        android:id="@+id/tvHistoryIngredients"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingStart="60dp"
        android:text="Nguyên liệu..."
        android:textColor="#6B7280"
        android:textSize="12sp"
        android:lineSpacingExtra="2dp"
        android:maxLines="5"
        android:ellipsize="end" />

</LinearLayout>
