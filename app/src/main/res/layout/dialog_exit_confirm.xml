<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_exit"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="28dp"
    android:paddingTop="32dp"
    android:paddingBottom="24dp">

    <!-- Icon cảnh báo trong vòng tròn hồng -->
    <FrameLayout
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:background="@drawable/bg_exit_icon_circle">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_exit"
            android:importantForAccessibility="no" />
    </FrameLayout>

    <!-- Tiêu đề -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="sans-serif-medium"
        android:text="Thoát ứng dụng?"
        android:textColor="#1A1A2E"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Mô tả -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="Dữ liệu của bạn đã được lưu tự động.\nBạn có chắc muốn thoát PantrySmart?"
        android:textColor="#6B7280"
        android:textSize="14sp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="24dp"
        android:background="#F0F0F0" />

    <!-- Hai nút hành động -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <!-- Nút Ở lại -->
        <TextView
            android:id="@+id/btnExitCancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_exit_cancel"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="Hủy"
            android:textColor="#374151"
            android:textSize="15sp" />

        <!-- Nút Thoát -->
        <TextView
            android:id="@+id/btnExitConfirm"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_exit_confirm"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="Thoát"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />
    </LinearLayout>

</LinearLayout>
