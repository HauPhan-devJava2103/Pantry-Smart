<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp"
    app:strokeColor="#F9FAFB"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="13dp"
        android:paddingVertical="12dp">

        <!-- Icon danh mục -->
        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_budget_category_icon_trans">
            <ImageView
                android:id="@+id/imgTransactionIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:scaleType="centerInside"
                android:contentDescription="Transaction icon" />
        </FrameLayout>

        <!-- Tên + thông tin -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTransactionName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:textColor="#364153"
                android:textSize="14sp"
                tools:text="Chợ Long Biên rau" />

            <TextView
                android:id="@+id/tvTransactionInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:textColor="#99A1AF"
                android:textSize="11sp"
                tools:text="Mua sắm • 06-04" />
        </LinearLayout>

        <!-- Số tiền + nút Edit/Delete -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvTransactionAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#FB2C36"
                android:textSize="13sp"
                tools:text="-85,000đ" />

            <!-- Nút Sửa -->
            <ImageView
                android:id="@+id/btnEditTransaction"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/bg_circle_edit"
                android:clickable="true"
                android:focusable="true"
                android:padding="6dp"
                android:src="@drawable/ic_action_edit"
                app:tint="#3B82F6" />

            <!-- Nút Xóa -->
            <ImageView
                android:id="@+id/btnDeleteTransaction"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_circle_delete"
                android:clickable="true"
                android:focusable="true"
                android:padding="6dp"
                android:src="@drawable/ic_action_delete"
                app:tint="#EF4444" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
