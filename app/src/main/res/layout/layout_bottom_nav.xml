<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom Navigation — Synced from Figma (node 1:6290) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Top border line (Figma: #F3F4F6, 1.275px) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F3F4F6" />

    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="63dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bg_card"
        android:elevation="8dp"
        android:baselineAligned="false">

        <!-- ==================== -->
        <!-- Tab 1: Tủ lạnh       -->
        <!-- ==================== -->
        <FrameLayout
            android:id="@+id/navTabFridge"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true">

            <!-- Active indicator bar (shown when this tab is active) -->
            <View
                android:id="@+id/navIndicatorFridge"
                android:layout_width="32dp"
                android:layout_height="2dp"
                android:layout_gravity="top|center_horizontal"
                android:background="@drawable/bg_nav_indicator"
                android:visibility="visible" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:id="@+id/navIconFridge"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_nav_fridge"
                    android:contentDescription="@string/tab_fridge"
                    app:tint="@color/primary_dark" />

                <TextView
                    android:id="@+id/navLabelFridge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tab_fridge"
                    android:textSize="10sp"
                    android:textColor="@color/primary_dark"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </FrameLayout>

        <!-- ==================== -->
        <!-- Tab 2: Gợi ý         -->
        <!-- ==================== -->
        <FrameLayout
            android:id="@+id/navTabSuggest"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true">

            <View
                android:id="@+id/navIndicatorSuggest"
                android:layout_width="32dp"
                android:layout_height="2dp"
                android:layout_gravity="top|center_horizontal"
                android:background="@drawable/bg_nav_indicator"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:id="@+id/navIconSuggest"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_nav_suggest"
                    android:contentDescription="@string/tab_suggest"
                    app:tint="@color/text_hint" />

                <TextView
                    android:id="@+id/navLabelSuggest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tab_suggest"
                    android:textSize="10sp"
                    android:textColor="@color/text_hint"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </FrameLayout>

        <!-- ==================== -->
        <!-- Tab 3: Ngân sách     -->
        <!-- ==================== -->
        <FrameLayout
            android:id="@+id/navTabBudget"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true">

            <View
                android:id="@+id/navIndicatorBudget"
                android:layout_width="32dp"
                android:layout_height="2dp"
                android:layout_gravity="top|center_horizontal"
                android:background="@drawable/bg_nav_indicator"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="12dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:id="@+id/navIconBudget"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_nav_budget"
                    android:contentDescription="@string/tab_budget"
                    app:tint="@color/text_hint" />

                <TextView
                    android:id="@+id/navLabelBudget"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tab_budget"
                    android:textSize="10sp"
                    android:textColor="@color/text_hint"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>
</LinearLayout>
