<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_warning_item_row"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:layout_marginBottom="6dp"
    android:padding="12dp">

    <!-- Dot cảnh báo -->
    <View
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/bg_notification_badge"
        android:backgroundTint="#FF8F00" />

    <!-- Tên nguyên liệu -->
    <TextView
        android:id="@+id/tvWarningName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="sans-serif-medium"
        android:text="Trứng gà"
        android:textColor="#1A1A2E"
        android:textSize="13sp" />

    <!-- Thông tin tồn kho / yêu cầu -->
    <TextView
        android:id="@+id/tvWarningDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif"
        android:text="còn 2 / cần 5"
        android:textColor="#E65100"
        android:textSize="12sp" />

</LinearLayout>
