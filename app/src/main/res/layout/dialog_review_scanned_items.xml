<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_main"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kiểm tra danh sách"
        android:textColor="#1F2937"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvReviewSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Gemini đã trích xuất 5 thực phẩm từ hóa đơn của bạn."
        android:textColor="#6B7280"
        android:textSize="14sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="16dp"
        android:background="#F3F4F6" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvReviewScannedItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="400dp"
        android:scrollbars="vertical" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="16dp"
        android:background="#F3F4F6" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnCancelReview"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_scan_secondary"
            android:gravity="center"
            android:text="Hủy"
            android:textColor="#4B5563"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnSaveAllScanned"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1.5"
            android:background="@drawable/bg_btn_scan_primary"
            android:gravity="center"
            android:text="Thêm tất cả (5)"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
