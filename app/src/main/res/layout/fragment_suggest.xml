<?xml version="1.0" encoding="utf-8"?>
<!-- Fragment "Gợi ý" — Swipeable recipe suggestions powered by Gemini AI -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Animated gradient background (color transitions on swipe) -->
    <View
        android:id="@+id/bgGradient"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_suggest_gradient_1" />

    <!-- ViewPager2 with transparent items (bg handled by bgGradient) -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerRecipes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Loading State — Premium cooking animation -->
    <LinearLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_suggest_gradient_1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible">

        <!-- Lottie Animation nấu ăn -->
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/ivLoadingIcon"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:scaleType="fitCenter"
            app:lottie_rawRes="@raw/cooking"
            app:lottie_autoPlay="true"
            app:lottie_loop="true" />

        <!-- Thanh progress ngang mềm mại -->
        <ProgressBar
            android:layout_width="200dp"
            android:layout_height="4dp"
            android:layout_marginTop="24dp"
            android:indeterminate="true"
            android:indeterminateTint="#FFFFFF"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal" />

        <!-- Text chính -->
        <TextView
            android:id="@+id/tvLoadingTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/suggest_loading"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

        <!-- Text phụ thay đổi (step indicator) -->
        <TextView
            android:id="@+id/tvLoadingStep"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif"
            android:text="@string/suggest_loading_sub"
            android:textColor="#B0FFFFFF"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Error / Empty State -->
    <LinearLayout
        android:id="@+id/errorOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_suggest_gradient_1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_suggest_empty"
            android:contentDescription="@string/suggest_empty" />

        <TextView
            android:id="@+id/tvErrorMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="@string/suggest_empty"
            android:textColor="#1E1E2E"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/btnRetry"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_suggest_btn_cook"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:text="@string/suggest_retry"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

</FrameLayout>
