<?xml version="1.0" encoding="utf-8"?>
<!-- FAB menu nổi — nút Thêm thực phẩm với 3 tùy chọn mở rộng -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fabContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Overlay mờ khi menu mở -->
    <View
        android:id="@+id/fabOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true" />

    <!-- Menu items — xuất hiện từ dưới lên khi mở -->
    <LinearLayout
        android:id="@+id/fabMenuItems"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="80dp"
        android:visibility="gone">

        <!-- Item 1: Nhận diện AI -->
        <LinearLayout
            android:id="@+id/fabItemAI"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true">

            <!-- Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_fab_label"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center"
                android:text="Nhận diện AI"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:layout_marginEnd="12dp" />

            <!-- Icon circle -->
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_fab_item_gray">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_camera"
                    android:contentDescription="AI" />
            </FrameLayout>
        </LinearLayout>

        <!-- Item 2: Quét hóa đơn -->
        <LinearLayout
            android:id="@+id/fabItemScan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_fab_label"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center"
                android:text="Quét hóa đơn"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:layout_marginEnd="12dp" />

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_fab_item_purple">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_scan"
                    android:contentDescription="Quét" />
            </FrameLayout>
        </LinearLayout>

        <!-- Item 3: Thêm thủ công -->
        <LinearLayout
            android:id="@+id/fabItemManual"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_fab_label"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center"
                android:text="Thêm thủ công"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:layout_marginEnd="12dp" />

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_fab_item_orange">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_edit"
                    android:contentDescription="Thêm" />
            </FrameLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- FAB chính -->
    <FrameLayout
        android:id="@+id/fabMain"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_fab_main"
        android:elevation="6dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/fabMainIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_add"
            android:contentDescription="Thêm" />
    </FrameLayout>

</FrameLayout>
