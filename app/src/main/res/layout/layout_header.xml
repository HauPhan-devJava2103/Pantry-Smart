<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/headerContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_header_gradient"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Decorative circle (large, top-right, partially clipped) -->
    <View
        android:layout_width="112dp"
        android:layout_height="112dp"
        android:layout_gravity="end"
        android:layout_marginTop="-32dp"
        android:layout_marginEnd="-12dp"
        android:background="@drawable/bg_header_circle_large" />

    <!-- Decorative circle (small, right area) -->
    <View
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="end"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_header_circle_small" />

    <!-- Header content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="18dp">

        <!-- ROW 1: Greeting + Notification + Avatar    -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Greeting area (left) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Greeting text (dynamic: Chào buổi sáng/chiều/tối) -->
                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/greeting_morning"
                    app:drawableEndCompat="@drawable/ic_sun"
                    android:drawablePadding="6dp"
                    android:textSize="13sp"
                    android:textColor="@color/white_60"
                    android:fontFamily="sans-serif" />

                <!-- App title (dynamic: "Tủ lạnh có X món") -->
                <TextView
                    android:id="@+id/tvHeaderTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tủ lạnh có 0 món"
                    android:textSize="20sp"
                    android:textColor="@color/white"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Notification bell button -->
            <FrameLayout
                android:id="@+id/btnNotification"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="10dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Thông báo">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_notification"
                    app:tint="@color/white" />

                <!-- Notification count badge -->
                <TextView
                    android:id="@+id/tvNotificationBadge"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/bg_notification_badge"
                    android:gravity="center"
                    android:text="2"
                    android:textSize="9sp"
                    android:textColor="@color/white"
                    android:fontFamily="sans-serif-medium"
                    android:visibility="visible" />
            </FrameLayout>

            <!-- Avatar / Profile button -->
            <FrameLayout
                android:id="@+id/btnProfile"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Tài khoản"
                android:background="@drawable/bg_avatar_placeholder">

                <ImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_user"
                    app:tint="@color/white" />
            </FrameLayout>
        </LinearLayout>

        <!-- ========================================== -->
        <!-- ROW 2: Search bar + Expiry badge           -->
        <!-- ========================================== -->
        <LinearLayout
            android:id="@+id/headerRow2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="14dp">

            <!-- Search bar -->
            <LinearLayout
                android:id="@+id/searchBar"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_search_bar"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginEnd="10dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_search"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="Tìm kiếm"
                    app:tint="@color/white_60" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tìm thực phẩm..."
                    android:textSize="13sp"
                    android:textColor="@color/white_60"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

            <!-- Expiry badge -->
            <LinearLayout
                android:id="@+id/badgeExpiry"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minWidth="48dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_expiry_badge"
                android:paddingStart="10dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true">

                <!-- Animated orange dot -->
                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_notification_badge"
                    android:backgroundTint="#FFB86A"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvExpiryBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 sắp hết"
                    android:textSize="11sp"
                    android:textColor="@color/white"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
