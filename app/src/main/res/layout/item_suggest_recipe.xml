<?xml version="1.0" encoding="utf-8"?>
<!-- Item cho ViewPager2 — Mỗi trang là một gợi ý món ăn (swipeable) -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="24dp">

        <!-- Top spacer -->
        <Space
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:layout_weight="0.8" />

        <!-- Header question -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:lineSpacingExtra="6dp"
            android:text="@string/suggest_header"
            android:textColor="#1E1E2E"
            android:textSize="26sp" />

        <Space
            android:layout_width="1dp"
            android:layout_height="28dp" />

        <!-- Food name chip -->
        <TextView
            android:id="@+id/tvFoodName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_suggest_chip"
            android:fontFamily="sans-serif-medium"
            android:text="Trứng chiên"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <Space
            android:layout_width="1dp"
            android:layout_height="28dp" />

        <!-- Food image with subtle circle backdrop -->
        <FrameLayout
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_gravity="center_horizontal">

            <!-- Semi-transparent circle backdrop -->
            <View
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_suggest_image_circle" />

            <!-- Food image (loaded via Glide) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center"
                app:cardCornerRadius="24dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="@android:color/transparent">

                <ImageView
                    android:id="@+id/ivFoodImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <!-- Middle spacer -->
        <Space
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Swipe hint with vector arrows -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:drawablePadding="6dp"
            android:fontFamily="sans-serif"
            android:gravity="center_vertical"
            android:text="@string/suggest_swipe_hint"
            android:textColor="#501E1E2E"
            android:textSize="12sp"
            app:drawableStartCompat="@drawable/ic_chevron_left"
            app:drawableEndCompat="@drawable/ic_chevron_right"
            app:drawableTint="#501E1E2E" />

        <!-- Start cooking button -->
        <TextView
            android:id="@+id/btnStartCooking"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_suggest_btn_cook"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="sans-serif-bold"
            android:gravity="center"
            android:text="@string/suggest_btn_cook"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

    </LinearLayout>
</FrameLayout>
