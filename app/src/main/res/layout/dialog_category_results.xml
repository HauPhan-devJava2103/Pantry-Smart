<?xml version="1.0" encoding="utf-8"?>
<!-- Dialog kết quả lọc thực phẩm theo danh mục -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_bottom_sheet"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_dialog_handle" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <!-- Category icon circle -->
        <FrameLayout
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_status_badge_fresh">

            <ImageView
                android:id="@+id/ivCategoryResultIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_food_broccoli"
                android:contentDescription="Danh mục" />
        </FrameLayout>

        <!-- Title + Count -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvCategoryResultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Rau củ"
                android:textColor="#1F2937"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvCategoryResultSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="0 thực phẩm tìm thấy"
                android:textColor="#9CA3AF"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Close -->
        <FrameLayout
            android:id="@+id/btnCloseCategoryResult"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_dialog_close_btn">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_close"
                android:contentDescription="Đóng" />
        </FrameLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:background="#F1F5F9" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/layoutCategoryEmpty"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_find"
            android:alpha="0.3"
            android:contentDescription="Trống" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Không có thực phẩm nào\ntrong danh mục này"
            android:textAlignment="center"
            android:textColor="#9CA3AF"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Results RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCategoryResults"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="420dp"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:paddingTop="10dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:clipToPadding="false"
        android:nestedScrollingEnabled="false" />

</LinearLayout>
