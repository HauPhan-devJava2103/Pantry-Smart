<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="56dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="#E5E7EB" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:fontFamily="sans-serif-medium"
        android:text="Tùy chọn hiển thị"
        android:textColor="#1E2939"
        android:textSize="18sp" />

    <LinearLayout
        android:id="@+id/btnModeMonth"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_category_unselected"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/iconModeMonth"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_my_calendar"
            app:tint="#4A5565" />

        <TextView
            android:id="@+id/tvModeMonth"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="Theo tháng"
            android:textColor="#4A5565"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/iconCheckMonth"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_toast_check"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/btnModeWeek"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_category_unselected"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/iconModeWeek"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_today"
            app:tint="#4A5565" />

        <TextView
            android:id="@+id/tvModeWeek"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="Theo tuần"
            android:textColor="#4A5565"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/iconCheckWeek"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_toast_check"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
