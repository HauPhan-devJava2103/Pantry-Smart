<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_rounded"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="28dp"
    android:paddingBottom="20dp">

    <!-- Icon -->
    <ImageView
        android:id="@+id/imgDialogIcon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_budget_warning" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="Xác nhận xóa"
        android:textColor="#1E2939"
        android:textSize="17sp"
        android:textStyle="bold" />

    <!-- Message -->
    <TextView
        android:id="@+id/tvDialogMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="Nội dung xác nhận"
        android:textColor="#4A5565"
        android:textSize="14sp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:background="#F0F1F3" />

    <!-- Danger Button (Primary) -->
    <TextView
        android:id="@+id/btnDialogDanger"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_btn_dialog_danger"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="Xóa"
        android:textColor="#FFFFFF"
        android:textSize="15sp" />

    <!-- Neutral Button (middle option, hidden by default) -->
    <TextView
        android:id="@+id/btnDialogNeutral"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_btn_dialog_secondary"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="Chỉ xóa giao dịch"
        android:textColor="#4A5565"
        android:textSize="14sp"
        android:visibility="gone" />

    <!-- Cancel Button -->
    <TextView
        android:id="@+id/btnDialogCancel"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_btn_dialog_secondary"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="Hủy"
        android:textColor="#4A5565"
        android:textSize="14sp" />

</LinearLayout>
