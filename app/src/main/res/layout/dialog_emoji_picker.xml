<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_bottom_sheet"
    android:paddingBottom="16dp">

    <!-- Handle Bar -->
    <View
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_dialog_handle" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/tvEmojiPickerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chọn biểu tượng"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1E2939"
            android:fontFamily="sans-serif-medium" />

        <FrameLayout
            android:id="@+id/btnCloseEmojiPicker"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/bg_edit_close_btn"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="✕"
                android:textSize="14sp"
                android:textColor="#6B7280" />
        </FrameLayout>
    </LinearLayout>

    <!-- Subtitle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chọn emoji đại diện cho thực phẩm"
        android:textSize="13sp"
        android:textColor="#9CA3AF"
        android:gravity="center"
        android:paddingBottom="12dp" />

    <!-- Tab nhóm -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/layoutEmojiGroupTabs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="2dp"
            android:paddingBottom="14dp" />

    </HorizontalScrollView>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F3F4F6"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp" />

    <!-- Grid emoji -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvEmojiGrid"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:clipToPadding="false"
        android:overScrollMode="never" />

</LinearLayout>
