<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/bg_ai_scanning_dialog"
    android:paddingStart="28dp"
    android:paddingEnd="28dp"
    android:paddingTop="20dp"
    android:paddingBottom="20dp"
    android:minWidth="260dp">

    <!-- Lottie Animation -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieAI"
        android:layout_width="120dp"
        android:layout_height="120dp"
        app:lottie_rawRes="@raw/ai_scan"
        app:lottie_autoPlay="true"
        app:lottie_loop="true" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvAITitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI đang nhận diện..."
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginTop="8dp" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvAISubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Đang phân tích hình ảnh"
        android:textSize="13sp"
        android:textColor="#7A7A8E"
        android:layout_marginTop="4dp" />

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressAI"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="14dp"
        android:indeterminate="true"
        android:progressTint="#4CAF50"
        android:progressBackgroundTint="#E8F5E9" />

</LinearLayout>
