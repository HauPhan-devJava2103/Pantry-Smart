<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_sheet_rounded"
    android:paddingBottom="24dp">

    <!-- Handle -->
    <View
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_sheet_handle" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="16dp"
        android:text="Thêm chi tiêu"
        android:fontFamily="sans-serif-medium"
        android:textColor="#1E2939"
        android:textSize="18sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:layout_marginTop="16dp">

        <EditText
            android:id="@+id/etExpenseName"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:background="@drawable/bg_edittext_expense"
            android:hint="Tên chi tiêu (vd: Siêu thị Vinmart)"
            android:textColorHint="#800A0A0A"
            android:textColor="#1E2939"
            android:textSize="14sp"
            android:paddingHorizontal="12dp"
            android:inputType="text" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp">

            <EditText
                android:id="@+id/etExpenseAmount"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:background="@drawable/bg_edittext_expense"
                android:hint="Số tiền (VND)"
                android:textColorHint="#800A0A0A"
                android:textColor="#1E2939"
                android:textSize="14sp"
                android:paddingHorizontal="12dp"
                android:inputType="numberDecimal" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Quick add chips -->
                    <TextView
                        android:id="@+id/chip20k"
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_chip_expense"
                        android:text="20k"
                        android:textColor="#4A5565"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:paddingHorizontal="12dp" />

                    <TextView
                        android:id="@+id/chip50k"
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_chip_expense"
                        android:layout_marginStart="6dp"
                        android:text="50k"
                        android:textColor="#4A5565"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:paddingHorizontal="12dp" />

                    <TextView
                        android:id="@+id/chip100k"
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_chip_expense"
                        android:layout_marginStart="6dp"
                        android:text="100k"
                        android:textColor="#4A5565"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:paddingHorizontal="12dp" />

                    <TextView
                        android:id="@+id/chip150k"
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_chip_expense"
                        android:layout_marginStart="6dp"
                        android:text="150k"
                        android:textColor="#4A5565"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:paddingHorizontal="12dp" />

                    <TextView
                        android:id="@+id/chip200k"
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_chip_expense"
                        android:layout_marginStart="6dp"
                        android:text="200k"
                        android:textColor="#4A5565"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:paddingHorizontal="12dp" />

                    <TextView
                        android:id="@+id/chip300k"
                        android:layout_width="wrap_content"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_chip_expense"
                        android:layout_marginStart="6dp"
                        android:text="300k"
                        android:textColor="#4A5565"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:paddingHorizontal="12dp" />
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Danh mục"
            android:textColor="#99A1AF"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="6dp">

            <!-- Category Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <!-- Mua sắm (Selected) -->
                <LinearLayout
                    android:id="@+id/btnCatShopping"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_category_selected"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛒"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Mua sắm"
                        android:textColor="#00BC7D"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- Giao hàng -->
                <LinearLayout
                    android:id="@+id/btnCatDelivery"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_category_unselected"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛵"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Giao hàng"
                        android:textColor="#4A5565"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </LinearLayout>

            <!-- Category Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:baselineAligned="false">

                <!-- Đồ ăn vặt -->
                <LinearLayout
                    android:id="@+id/btnCatSnacks"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_category_unselected"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🍿"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Đồ ăn vặt"
                        android:textColor="#4A5565"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- Khác -->
                <LinearLayout
                    android:id="@+id/btnCatOthers"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_category_unselected"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📦"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Khác"
                        android:textColor="#4A5565"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Ngày"
            android:textColor="#99A1AF"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvSelectDate"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_edittext_expense"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:text=""
            android:textColor="#1E2939"
            android:textSize="14sp"
            app:drawableEndCompat="@android:drawable/ic_menu_today"
            app:drawableTint="#99A1AF" />

        <Button
            android:id="@+id/btnSaveExpense"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_gradient"
            android:text="Lưu chi tiêu"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:textAllCaps="false"
            app:backgroundTint="@null" />

    </LinearLayout>
</LinearLayout>
