<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_rounded"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="28dp"
    android:paddingBottom="20dp">

    <!-- Icon -->
    <ImageView
        android:id="@+id/imgDialogIcon"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_budget_danger" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="Vượt ngân sách!"
        android:textColor="#1E2939"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Message -->
    <TextView
        android:id="@+id/tvDialogMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="Nội dung cảnh báo"
        android:textColor="#4A5565"
        android:textSize="14sp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:background="#F0F1F3" />

    <!-- Primary Button -->
    <TextView
        android:id="@+id/btnDialogPrimary"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_btn_dialog_primary"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="Đã hiểu"
        android:textColor="#FFFFFF"
        android:textSize="15sp" />

    <!-- Secondary Button -->
    <TextView
        android:id="@+id/btnDialogSecondary"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_btn_dialog_secondary"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="Điều chỉnh ngân sách"
        android:textColor="#4A5565"
        android:textSize="14sp" />

</LinearLayout>
