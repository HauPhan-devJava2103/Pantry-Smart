<?xml version="1.0" encoding="utf-8"?>
<!-- Freezer door: cool blue-white gradient with metallic sheen -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Door surface -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#F0F5FA"
                android:centerColor="#E8EDF4"
                android:endColor="#DCE4EF"
                android:angle="160" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <!-- Top reflection highlight -->
    <item android:bottom="100dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#40FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
            <corners android:topLeftRadius="14dp" android:topRightRadius="14dp" />
        </shape>
    </item>
    <!-- Inner shadow (inset effect) -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="0.5dp" android:color="#20000000" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</layer-list>
