<?xml version="1.0" encoding="utf-8"?>
<!-- Food item with warning ring: orange-tinted circle for expiring items -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#FFF5EB" />
            <stroke android:width="1.5dp" android:color="#FF8C42" />
            <size android:width="42dp" android:height="42dp" />
        </shape>
    </item>
</layer-list>
