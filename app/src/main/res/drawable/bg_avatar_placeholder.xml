<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- White ring border -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/white_40" />
        </shape>
    </item>
    <!-- Inner circle with icon color -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="oval">
            <solid android:color="@color/white_20" />
        </shape>
    </item>
</layer-list>
