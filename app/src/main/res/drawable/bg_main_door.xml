<?xml version="1.0" encoding="utf-8"?>
<!-- Main compartment door: warm white gradient with metallic sheen -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Door surface -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FAFBFC"
                android:centerColor="#F2F4F7"
                android:endColor="#E8ECF0"
                android:angle="160" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <!-- Top reflection highlight -->
    <item android:bottom="120dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#50FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
            <corners android:topLeftRadius="14dp" android:topRightRadius="14dp" />
        </shape>
    </item>
    <!-- Inner shadow -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="0.5dp" android:color="#18000000" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</layer-list>
