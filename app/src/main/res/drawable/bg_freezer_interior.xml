<?xml version="1.0" encoding="utf-8"?>
<!-- Freezer interior: colder blue tint -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#D8E8F8"
                android:centerColor="#E4EEF9"
                android:endColor="#D0E2F5"
                android:angle="270" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <!-- Frost overlay -->
    <item android:bottom="80dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#40FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
            <corners android:topLeftRadius="12dp" android:topRightRadius="12dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="1.5dp" android:color="#18000000" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</layer-list>
