<?xml version="1.0" encoding="utf-8"?>
<!-- Fridge door handle: metallic silver gradient bar with 3D shape -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Handle shadow -->
    <item android:left="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#25000000" />
            <corners android:radius="3dp" />
        </shape>
    </item>
    <!-- Handle body -->
    <item android:right="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#D4D9E0"
                android:centerColor="#F0F2F5"
                android:endColor="#C8CDD4"
                android:angle="0" />
            <corners android:radius="3dp" />
            <stroke android:width="0.5dp" android:color="#B0B5BC" />
        </shape>
    </item>
    <!-- Handle highlight -->
    <item android:left="2dp" android:right="3dp" android:top="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#20FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="0" />
            <corners android:radius="2dp" />
        </shape>
    </item>
</layer-list>
